{
  "tfidf_word": {
    "features": {
      "payload": {
        "dask_ml.feature_extraction.text.CountVectorizer": {
          "params": {
            "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{3,32}\\b",
            "lowercase": false,
            "max_df": 0.7,
            "max_features": 1000
          }
        },
        "pipeline.transformations.wrappers.TfidfTransformerWrapper": {
          "params": {"norm": "l1"}
        }
      }
    },
    "estimators": {
      "isolation_forest": [{
        "class": "pyod.models.iforest.IForest",
        "params": {"n_estimators": 100},
        "grid": {  "bootstrap": [false, true],
        "contamination": [0.1, 0.2, 0.3] }
      }],
      "ECOD": [
        {
          "class": "pyod.models.ecod.ECOD",
          "grid": { "contamination": [0.1, 0.2, 0.3] }
        }
      ],
      "knn": [
        {
          "class": "pyod.models.knn.KNN",
          "grid": { 
            "n_neighbors": [5, 10],
            "contamination": [0.1, 0.2, 0.3] }
        }
      ],
      "lof": [
        {
          "class": "pyod.models.lof.LOF",
          "grid": { 
            "n_neighbors": [10, 20],
            "contamination": [0.1, 0.2, 0.3] }
        }
      ],
      "vae": [
        {
          "class": "pyod.models.vae.VAE",
          "grid": { 
            "epoch_num": [20, 50],
            "contamination": [0.1, 0.2, 0.3] }
        }
      ]
    }
  },
  "ngram_tfidf": {
    "features": {
      "payload": {
        "dask_ml.feature_extraction.text.CountVectorizer": {
          "params": {
            "analyzer": "char",
            "lowercase": false,
            "max_features": 1000,
            "max_df": 0.7
          },
          "grid": {
            "ngram_range": [[2, 2]]
          }
        },
          "pipeline.transformations.wrappers.TfidfTransformerWrapper": {
          "params": {"norm": "l1"}
