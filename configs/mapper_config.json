{
  "count_vectorizer": {
    "max_features": 200,
    "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{4,}\\b",
    "lowercase": false,
    "min_df": 10,
    "max_df": 0.5
  },
  "frequency_encode": {
    "normalize": false,
    "max_features": 200,
    "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{4,}\\b",
    "min_df": 10,
    "max_df": 0.5
  },
  "ngram_vectorizer": {
    "max_features": 200,
    "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{4,}\\b",
    "lowercase": false,
    "min_df": 10,
    "max_df": 0.5,
    "ngram_range": [2, 2]
  },
  "binary_encode": {
    "bits": 12,
    "hash_seed": 0,
    "drop_original": true
  },
  "text_stats": {
    "compression": true
  },
  "tfidf": {
    "max_features": 200,
    "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{4,}\\b",
    "lowercase": false,
    "min_df": 10,
    "max_df": 0.5,
    "sublinear_tf": true
  },
  "char_vectorizer": {
    "max_features": 200,
    "ngram_range": [2, 4],
    "analyzer": "char_wb",
    "lowercase": false,
    "min_df": 10,
    "max_df": 0.5
  }
}