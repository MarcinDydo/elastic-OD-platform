{
  "fasttext":{
    "features": {
      "content": {
        "pipeline.transformations.wrappers.DocumentPoolWrapper": {
          "params": {
            "model": "./data/csic-01-fasttext2.bin",
            "pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{3,}\\b"
          }
        }
      },
