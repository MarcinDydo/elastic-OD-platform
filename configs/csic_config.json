  "char_ae": {
    "features": {
      "URL": {
        "dask_ml.feature_extraction.text.CountVectorizer": {
          "params": {
            "analyzer": "char_wb",
            "lowercase": false,
            "max_features": 1000
          },
          "grid": {
            "max_df": [0.3, 0.8],
            "ngram_range": [[2, 2]]
          }
        },
        "pipeline.transformers.wrappers.AutoencoderWrapper": {
          "params": {
            "hidden_neurons": [1000, 500, 50],
            "epochs": 30
          }
        }
      }
    },
    "estimators": {
      "isolation_forest": [{
        "class": "pyod.models.iforest.IForest",
        "grid": { "n_estimators": [50, 100] ,"contamination": [0.1, 0.2, 0.3]}
      }],
