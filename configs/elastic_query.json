{
  "_source": [
    "rule.rule",
    "rule.name",
    "message"
  ],
  "query": {
    "bool": {
      "filter": [
        { "term": { "data_stream.dataset": "suricata" } },
        { "range": {
    "@timestamp": {
      "gte": "2026-04-25T00:00:00.000Z",
      "lte": "2026-04-29T23:59:59.999Z"
    }
  }}
      ],
      "must_not": [
        {
          "query_string": {
            "fields": ["rule.name"],
            "query": "GPL SNMP public access udp"}
        }
      ]
    }
  }
}