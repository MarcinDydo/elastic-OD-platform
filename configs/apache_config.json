{
  "fasttext": {
    "features": {
      "request": {
        "pipeline.transformations.wrappers.DocumentPoolWrapper": {
          "params": {
            "model": "./data/Apache-access-log-web-Intrusion-Detection-fasttext.bin",
            "pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{3,32}\\b"
          }
        }
      },
      "referer": {
        "pipeline.transformations.wrappers.DocumentPoolWrapper": {
          "params": {
            "model": "./data/Apache-access-log-web-Intrusion-Detection-fasttext.bin",
            "pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{3,32}\\b"
          }
        }
      },
      "browser": {
        "pipeline.transformations.wrappers.DocumentPoolWrapper": {
          "params": {
            "model": "./data/Apache-access-log-web-Intrusion-Detection-fasttext.bin",
            "pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{3,32}\\b"
          }
        }
      }
    },
    "estimators": {
      "isolation_forest": [{
        "class": "pyod.models.iforest.IForest",
        "params": {"n_estimators": 100},
        "grid": {  "bootstrap": [false, true],
        "contamination": [0.1, 0.2, 0.3] }
      }],
      "ECOD": [
        {
          "class": "pyod.models.ecod.ECOD",
          "grid": { "contamination": [0.1, 0.2, 0.3] }
        }
      ],
      "Lunar": [
        {
          "class": "pyod.models.lunar.LUNAR",
          "grid": { 
            "n_neighbours": [5, 10],
            "contamination": [0.1, 0.2, 0.3] }
        }
      ],
      "vae": [
        {
          "class": "pyod.models.vae.VAE",
          "grid": { 
            "epoch_num": [20, 50],
            "contamination": [0.1, 0.2, 0.3] }
        }
      ]
    }
  }
}
