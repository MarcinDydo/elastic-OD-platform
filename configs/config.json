{
  "tfidf_svd": {
    "features": {
      "payload": {
        "sklearn.feature_extraction.text.TfidfVectorizer": {
          "params": {
            "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{4,12}\\b",
            "lowercase": false
          },
          "grid": {
            "max_features": [300, 600, 1000],
            "min_df": [5, 10, 20],
            "max_df": [0.3, 0.5]
          }
        },
        "pipeline.transformers.wrappers.TruncatedSVDWrapper": {
          "grid": { "n_components": [10, 50, 100] }
        }
      }
    },
    "estimators": {
      "isolation_forest": [{
        "callable": "sklearn.ensemble.IsolationForest",
        "params": { "n_estimators": 100 },
        "grid": { "contamination": [0.1, 0.2, 0.3] }
      }],
      "dbscan": [
        {
          "callable": "sklearn.cluster.DBSCAN",
          "grid": {
            "eps": [0.3, 0.5, 1],
            "min_samples": [10, 50]
          }
        }
      ],
      "ecod": [
        {
          "callable": "pyod.models.ecod.ECOD",
          "grid": { "contamination": [0.1, 0.2, 0.3] }
        }
      ]
    }
  },
 "char_svd": { 
    "features": {
      "payload": {
        "dask_ml.feature_extraction.text.CountVectorizer": {
          "params": {
            "analyzer": "char_wb",
            "lowercase": false
          },
          "grid": {
            "max_features": [300, 600, 1000],
            "min_df": [5, 10],
            "max_df": [0.3, 0.5],
            "ngram_range": [[2, 3]]
          }
        },
        "pipeline.transformers.wrappers.TruncatedSVDWrapper": {
          "grid": { "n_components": [25, 50, 75] }
        }
      }
    },
    "estimators": {
      "isolation_forest": [{
        "callable": "sklearn.ensemble.IsolationForest",
        "params": { "n_estimators": 100 },
        "grid": { "contamination": [0.05, 0.1, 0.2] }
      }],
      "dbscan": [
        {
          "callable": "sklearn.cluster.DBSCAN",
          "grid": {
            "eps": [0.5, 1.0],
            "min_samples": [50,100]
          }
        }
      ],
      "ecod": [
        {
          "callable": "pyod.models.ecod.ECOD",
          "grid": { "contamination": [0.1, 0.2, 0.3] }
        }
      ]
    }
  },
  "freq_svd": {
    "features": {
      "payload": {
        "pipeline.transformers.wrappers.PositionalIDFWrapper": {
          "params": {
            "token_pattern": "\\b(?![0-9]+\\b)(?![0-9]+[.\\-][0-9.\\-]*\\b)(?!(?:[0-9a-fA-F]{2}){2,}\\b)[a-zA-Z0-9._\\-%]{4,12}\\b",
            "max_features": 100,
            "normalize": false
          },
          "grid": {
            "max_features": [150, 300, 600],
            "min_df": [10, 20],
            "max_df": [0.3, 0.5]
          }
        },
        "pipeline.transformers.wrappers.TruncatedSVDWrapper": {
          "grid": { "n_components": [25, 50, 75] }
        }
      }
    },
    "estimators": {
      "isolation_forest": [{
        "callable": "sklearn.ensemble.IsolationForest",
        "params": { "n_estimators": 100 },
        "grid": { "contamination": [0.1, 0.2, 0.3] }
      }],
      "dbscan": [
        {
          "callable": "sklearn.cluster.DBSCAN",
          "grid": {
            "eps": [0.5, 0.8],
            "min_samples": [50, 100]
          }
        }
      ],
      "ecod": [
        {
          "callable": "pyod.models.ecod.ECOD",
          "grid": { "contamination": [0.05, 0.1, 0.2] }
        }
      ]
    }
  }
}